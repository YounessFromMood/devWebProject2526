# Dependances
/vendor/

# Variables d'environnement (ne jamais versionner)
.env

# Fichiers uploades par les utilisateurs (donnees, pas du code)
/public/uploads/profiles/*
!/public/uploads/profiles/.gitkeep

# Fichiers runtime de CodeIgniter
writable/cache/*
!writable/cache/index.html
writable/logs/*
!writable/logs/index.html
writable/session/*
!writable/session/index.html
writable/debugbar/*
writable/uploads/*

# Systeme d'exploitation
.DS_Store
Thumbs.db

# Editeurs / IDE
/.idea/
/.vscode/
*.sublime-project
*.sublime-workspace